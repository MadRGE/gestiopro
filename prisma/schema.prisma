generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// NextAuth.js - Tablas de autenticación
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==========================================
// Modelos del dominio
// ==========================================

model Usuario {
  id            String    @id @default(cuid())
  nombre        String
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  password      String?
  image         String?
  rol           Rol       @default(DUENIO)
  negocioId     String?   @map("negocio_id")
  creadoEl      DateTime  @default(now()) @map("creado_el")
  actualizadoEl DateTime  @updatedAt @map("actualizado_el")

  negocio     Negocio?     @relation(fields: [negocioId], references: [id])
  accounts    Account[]
  sessions    Session[]
  ventas      Venta[]
  cajasSesion CajaSesion[]

  @@map("usuarios")
}

enum Rol {
  ADMIN
  DUENIO
  EMPLEADO
}

model Rubro {
  id          String   @id @default(cuid())
  nombre      String   @unique
  descripcion String?
  icono       String?
  config      Json     @default("{}")
  activo      Boolean  @default(true)
  creadoEl    DateTime @default(now()) @map("creado_el")

  negocios Negocio[]

  @@map("rubros")
}

model Negocio {
  id            String   @id @default(cuid())
  nombre        String
  rubroId       String   @map("rubro_id")
  direccion     String?
  telefono      String?
  cuit          String?
  condicionFiscal String? @map("condicion_fiscal")
  activo        Boolean  @default(true)
  creadoEl      DateTime @default(now()) @map("creado_el")
  actualizadoEl DateTime @updatedAt @map("actualizado_el")

  rubro       Rubro        @relation(fields: [rubroId], references: [id])
  usuarios    Usuario[]
  productos   Producto[]
  ventas      Venta[]
  categorias  Categoria[]
  clientes    Cliente[]
  proveedores Proveedor[]
  cajasSesion CajaSesion[]

  @@map("negocios")
}

model Producto {
  id            String   @id @default(cuid())
  nombre        String
  descripcion   String?
  codigoBarras  String?  @map("codigo_barras")
  precioCompra  Decimal  @default(0) @map("precio_compra") @db.Decimal(12, 2)
  precioVenta   Decimal  @map("precio_venta") @db.Decimal(12, 2)
  stock         Int      @default(0)
  stockMinimo   Int      @default(0) @map("stock_minimo")
  unidad        String   @default("unidad")
  categoriaId   String?  @map("categoria_id")
  proveedorId   String?  @map("proveedor_id")
  negocioId     String   @map("negocio_id")
  activo        Boolean  @default(true)
  creadoEl      DateTime @default(now()) @map("creado_el")
  actualizadoEl DateTime @updatedAt @map("actualizado_el")

  negocio    Negocio     @relation(fields: [negocioId], references: [id])
  categoria  Categoria?  @relation(fields: [categoriaId], references: [id])
  proveedor  Proveedor?  @relation(fields: [proveedorId], references: [id])
  itemsVenta ItemVenta[]

  @@index([negocioId])
  @@index([codigoBarras])
  @@map("productos")
}

model Venta {
  id            String      @id @default(cuid())
  numero        Int
  total         Decimal     @db.Decimal(12, 2)
  descuento     Decimal     @default(0) @db.Decimal(12, 2)
  metodoPago    MetodoPago  @default(EFECTIVO) @map("metodo_pago")
  estado        EstadoVenta @default(COMPLETADA)
  negocioId     String      @map("negocio_id")
  vendedorId    String      @map("vendedor_id")
  clienteId     String?     @map("cliente_id")
  creadoEl      DateTime    @default(now()) @map("creado_el")

  negocio  Negocio     @relation(fields: [negocioId], references: [id])
  vendedor Usuario     @relation(fields: [vendedorId], references: [id])
  cliente  Cliente?    @relation(fields: [clienteId], references: [id])
  items    ItemVenta[]

  @@index([negocioId])
  @@index([creadoEl])
  @@map("ventas")
}

model ItemVenta {
  id         String  @id @default(cuid())
  ventaId    String  @map("venta_id")
  productoId String  @map("producto_id")
  cantidad   Int
  precio     Decimal @db.Decimal(12, 2)
  subtotal   Decimal @db.Decimal(12, 2)

  venta    Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])

  @@map("items_venta")
}

enum MetodoPago {
  EFECTIVO
  DEBITO
  CREDITO
  TRANSFERENCIA
  QR
}

enum EstadoVenta {
  COMPLETADA
  CANCELADA
  PENDIENTE
}

// ==========================================
// Proveedores
// ==========================================

enum CondicionPago {
  CONTADO
  TREINTA_DIAS
  SESENTA_DIAS
  NOVENTA_DIAS
}

model Proveedor {
  id              String         @id @default(cuid())
  nombre          String
  telefono        String?
  email           String?
  direccion       String?
  cuit            String?
  notas           String?
  nombreContacto  String?        @map("nombre_contacto")
  cargoContacto   String?        @map("cargo_contacto")
  condicionPago   CondicionPago  @default(CONTADO) @map("condicion_pago")
  cuentaBancaria  String?        @map("cuenta_bancaria")
  cbu             String?
  negocioId       String         @map("negocio_id")
  activo          Boolean        @default(true)
  creadoEl        DateTime       @default(now()) @map("creado_el")

  negocio   Negocio    @relation(fields: [negocioId], references: [id])
  productos Producto[]

  @@index([negocioId])
  @@map("proveedores")
}

// ==========================================
// Categorías
// ==========================================

model Categoria {
  id        String   @id @default(cuid())
  nombre    String
  negocioId String   @map("negocio_id")
  activo    Boolean  @default(true)
  creadoEl  DateTime @default(now()) @map("creado_el")

  negocio   Negocio    @relation(fields: [negocioId], references: [id])
  productos Producto[]

  @@index([negocioId])
  @@map("categorias")
}

// ==========================================
// Clientes
// ==========================================

model Cliente {
  id        String   @id @default(cuid())
  nombre    String
  telefono  String?
  email     String?
  negocioId String   @map("negocio_id")
  activo    Boolean  @default(true)
  creadoEl  DateTime @default(now()) @map("creado_el")

  negocio Negocio @relation(fields: [negocioId], references: [id])
  ventas  Venta[]

  @@index([negocioId])
  @@map("clientes")
}

// ==========================================
// Caja
// ==========================================

model CajaSesion {
  id           String     @id @default(cuid())
  negocioId    String     @map("negocio_id")
  usuarioId    String     @map("usuario_id")
  montoInicial Decimal    @default(0) @map("monto_inicial") @db.Decimal(12, 2)
  montoFinal   Decimal?   @map("monto_final") @db.Decimal(12, 2)
  estado       EstadoCaja @default(ABIERTA)
  abiertaEl    DateTime   @default(now()) @map("abierta_el")
  cerradaEl    DateTime?  @map("cerrada_el")

  negocio     Negocio          @relation(fields: [negocioId], references: [id])
  usuario     Usuario          @relation(fields: [usuarioId], references: [id])
  movimientos MovimientoCaja[]

  @@index([negocioId])
  @@map("cajas_sesion")
}

model MovimientoCaja {
  id           String         @id @default(cuid())
  cajaSesionId String         @map("caja_sesion_id")
  tipo         TipoMovimiento
  monto        Decimal        @db.Decimal(12, 2)
  descripcion  String?
  creadoEl     DateTime       @default(now()) @map("creado_el")

  cajaSesion CajaSesion @relation(fields: [cajaSesionId], references: [id])

  @@index([cajaSesionId])
  @@map("movimientos_caja")
}

enum EstadoCaja {
  ABIERTA
  CERRADA
}

enum TipoMovimiento {
  INGRESO
  EGRESO
}
