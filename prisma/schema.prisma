generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// NextAuth.js - Tablas de autenticación
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==========================================
// Modelos del dominio
// ==========================================

model Usuario {
  id            String    @id @default(cuid())
  nombre        String
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  password      String?
  image         String?
  rol           Rol       @default(DUENIO)
  negocioId     String?   @map("negocio_id")
  creadoEl      DateTime  @default(now()) @map("creado_el")
  actualizadoEl DateTime  @updatedAt @map("actualizado_el")

  negocio  Negocio?  @relation(fields: [negocioId], references: [id])
  accounts Account[]
  sessions Session[]
  ventas   Venta[]

  @@map("usuarios")
}

enum Rol {
  ADMIN
  DUENIO
  EMPLEADO
}

model Rubro {
  id          String   @id @default(cuid())
  nombre      String   @unique
  descripcion String?
  icono       String?
  config      Json     @default("{}")
  activo      Boolean  @default(true)
  creadoEl    DateTime @default(now()) @map("creado_el")

  negocios Negocio[]

  @@map("rubros")
}

model Negocio {
  id            String   @id @default(cuid())
  nombre        String
  rubroId       String   @map("rubro_id")
  direccion     String?
  telefono      String?
  cuit          String?
  condicionFiscal String? @map("condicion_fiscal")
  activo        Boolean  @default(true)
  creadoEl      DateTime @default(now()) @map("creado_el")
  actualizadoEl DateTime @updatedAt @map("actualizado_el")

  rubro     Rubro      @relation(fields: [rubroId], references: [id])
  usuarios  Usuario[]
  productos Producto[]
  ventas    Venta[]

  @@map("negocios")
}

model Producto {
  id            String   @id @default(cuid())
  nombre        String
  descripcion   String?
  codigoBarras  String?  @map("codigo_barras")
  precioCompra  Decimal  @default(0) @map("precio_compra") @db.Decimal(12, 2)
  precioVenta   Decimal  @map("precio_venta") @db.Decimal(12, 2)
  stock         Int      @default(0)
  stockMinimo   Int      @default(0) @map("stock_minimo")
  unidad        String   @default("unidad")
  categoriaId   String?  @map("categoria_id")
  negocioId     String   @map("negocio_id")
  activo        Boolean  @default(true)
  creadoEl      DateTime @default(now()) @map("creado_el")
  actualizadoEl DateTime @updatedAt @map("actualizado_el")

  negocio    Negocio     @relation(fields: [negocioId], references: [id])
  itemsVenta ItemVenta[]

  @@index([negocioId])
  @@index([codigoBarras])
  @@map("productos")
}

model Venta {
  id            String      @id @default(cuid())
  numero        Int
  total         Decimal     @db.Decimal(12, 2)
  metodoPago    MetodoPago  @default(EFECTIVO) @map("metodo_pago")
  estado        EstadoVenta @default(COMPLETADA)
  negocioId     String      @map("negocio_id")
  vendedorId    String      @map("vendedor_id")
  creadoEl      DateTime    @default(now()) @map("creado_el")

  negocio  Negocio     @relation(fields: [negocioId], references: [id])
  vendedor Usuario     @relation(fields: [vendedorId], references: [id])
  items    ItemVenta[]

  @@index([negocioId])
  @@index([creadoEl])
  @@map("ventas")
}

model ItemVenta {
  id         String  @id @default(cuid())
  ventaId    String  @map("venta_id")
  productoId String  @map("producto_id")
  cantidad   Int
  precio     Decimal @db.Decimal(12, 2)
  subtotal   Decimal @db.Decimal(12, 2)

  venta    Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])

  @@map("items_venta")
}

enum MetodoPago {
  EFECTIVO
  DEBITO
  CREDITO
  TRANSFERENCIA
  QR
}

enum EstadoVenta {
  COMPLETADA
  CANCELADA
  PENDIENTE
}
